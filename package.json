{
  "name": "okresky",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:portless": "PORTLESS_PORT=1355 portless \"$(git branch --show-current | tr '/' '-').okresky\" pnpm dev",
    "build": "pnpm data:roads && vite build",
    "preview": "vite preview",
    "data:roads": "node scripts/build-road-data.mjs",
    "data:osm-geometries": "node scripts/fetch-osm-road-geometries.mjs",
    "ts:check": "tsc --noEmit",
    "check": "pnpm data:roads && pnpm ts:check && pnpm build"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/router-plugin": "^1.168.18",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.18.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
