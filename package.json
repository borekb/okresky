{
  "name": "okresky",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:portless": "portless \"$(git branch --show-current | tr '/' '-').okresky\" pnpm dev",
    "build": "pnpm data:roads && vite build",
    "preview": "vite preview",
    "data:roads": "node scripts/build-road-data.mjs",
    "ts:check": "tsc --noEmit",
    "check": "pnpm data:roads && pnpm ts:check && pnpm build"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "@vitejs/plugin-react": "^5.1.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "nitro": "3.0.1-alpha.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.9.3"
  }
}
